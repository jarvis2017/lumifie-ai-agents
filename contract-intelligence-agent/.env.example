# Copy to .env and fill in. Loaded into your shell with:
#   set -a; . ./.env; set +a

# Model selection (alias or full id). Resolved by lumifie_core:
#   claude          -> claude-opus-4-8 (default)
#   gpt-4o          -> OpenAI GPT-4o
#   ollama/llama3.1 -> local Ollama (JSON-mode fallback, no tool use)
LITELLM_MODEL=claude

# Provider credentials — set the one(s) for the model you use (litellm reads these).
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_API_BASE=http://localhost:11434

# Shared lumifie_core overrides (optional; defaults shown).
LUMIFIE_MAX_TOKENS=8000
# LUMIFIE_TEMPERATURE=          # left unset; some models reject sampling params
# LUMIFIE_REASONING_EFFORT=     # low | medium | high (only sent if supported)
LUMIFIE_MAX_RETRIES=4
LUMIFIE_REQUEST_TIMEOUT=600
LUMIFIE_LOG_LEVEL=INFO

# Contract-agent specific.
CONTRACT_AGENT_MAX_CHUNK_CHARS=12000
CONTRACT_AGENT_MAX_ITERS=8
