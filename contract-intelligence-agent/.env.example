# Copy to .env and fill in. The CLI reads these from the environment.
# (Use a tool like direnv, or `set -a; . ./.env; set +a` to load .env into your shell.)

# Required: your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown).
CONTRACT_AGENT_MODEL=claude-opus-4-8
CONTRACT_AGENT_EFFORT=high            # low | medium | high | max
CONTRACT_AGENT_MAX_TOKENS=8000
CONTRACT_AGENT_MAX_CHUNK_CHARS=12000
CONTRACT_AGENT_MAX_ITERS=8
CONTRACT_AGENT_MAX_RETRIES=4
CONTRACT_AGENT_LOG_LEVEL=INFO
