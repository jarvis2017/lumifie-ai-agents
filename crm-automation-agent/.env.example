# Copy to .env and fill in. Loaded into your shell with:
#   set -a; . ./.env; set +a

# Model selection (alias or full id), resolved by lumifie_core:
#   claude -> claude-opus-4-8 (default) | gpt-4o | ollama/llama3.1 (JSON fallback)
LITELLM_MODEL=claude

# Provider credentials — set the one(s) for the model you use.
# (Not needed for `--source demo`, which uses the offline stub provider.)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_API_BASE=http://localhost:11434

# Shared lumifie_core overrides (optional).
LUMIFIE_MAX_TOKENS=8000
LUMIFIE_MAX_RETRIES=4
LUMIFIE_LOG_LEVEL=INFO

# CRM automation specific.
CRM_SOURCE=demo                       # demo (offline) | hubspot | airtable
CRM_RULES_PATH=config/rules.example.yaml
CRM_DB_PATH=crm_audit.db              # SQLite audit trail

# HubSpot (only for --source hubspot).
HUBSPOT_TOKEN=pat-...

# Airtable (only for --source airtable).
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_CONTACTS_TABLE=Contacts
AIRTABLE_DEALS_TABLE=Deals
AIRTABLE_TASKS_TABLE=Tasks
