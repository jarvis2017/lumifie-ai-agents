# Copy to .env and fill in. Load with: set -a; . ./.env; set +a
# NOTE: `rag-chatbot demo` works with NO key (offline stub + hashing embedding).

# Model selection (alias or full id), resolved by lumifie_core:
#   claude -> claude-opus-4-8 (default) | gpt-4o | ollama/llama3.1
LITELLM_MODEL=claude

# Provider credentials — set the one(s) for the model you use.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_API_BASE=http://localhost:11434

# Shared lumifie_core overrides (optional).
LUMIFIE_MAX_TOKENS=8000
LUMIFIE_MAX_RETRIES=4
LUMIFIE_LOG_LEVEL=INFO

# RAG chatbot specific.
RAG_DB_PATH=./chroma_rag           # Chroma persistence directory
RAG_COLLECTION=documents           # collection name
RAG_CHUNK_SIZE=1000                # characters per chunk
RAG_CHUNK_OVERLAP=150              # character overlap between chunks
RAG_TOP_K=4                        # chunks retrieved per question
RAG_EMBEDDING=auto                 # auto | sentence-transformers | hashing
RAG_ST_MODEL=all-MiniLM-L6-v2      # sentence-transformers model (extra: [st])
RAG_USER_AGENT=lumifie-rag-chatbot/0.1
