# Copy to .env and fill in. Loaded into your shell with:
#   set -a; . ./.env; set +a

# Model selection (alias or full id), resolved by lumifie_core:
#   claude -> claude-opus-4-8 (default) | gpt-4o | ollama/llama3.1 (JSON fallback)
LITELLM_MODEL=claude

# Provider credentials — set the one(s) for the model you use.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_API_BASE=http://localhost:11434

# Shared lumifie_core overrides (optional).
LUMIFIE_MAX_TOKENS=8000
LUMIFIE_MAX_RETRIES=4
LUMIFIE_LOG_LEVEL=INFO

# Regulatory-monitor specific.
RM_DB_PATH=reg_monitor.db          # SQLite history (enables run-over-run diffs)
RM_SEARCH_REGION=us-en             # DuckDuckGo region
RM_LOOKBACK_DAYS=7                 # how many days back to constrain searches
RM_MAX_QUERIES=6                   # max planner search queries to run
RM_RESULTS_PER_SEARCH=5            # results pulled per search query
RM_MAX_FINDINGS=40                 # cap on findings handed to the analyst
