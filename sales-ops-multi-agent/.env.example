# Copy to .env and fill in. Load with: set -a; . ./.env; set +a
# NOTE: `sales-ops run --demo --dry-run` works with NO key (offline stub provider).

# Model (conversation intelligence) via lumifie_core / litellm
LITELLM_MODEL=claude
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Shared lumifie_core overrides (optional)
LUMIFIE_MAX_TOKENS=8000
LUMIFIE_LOG_LEVEL=INFO

# Sales-ops specifics
SALESOPS_CONFIG=config/sales_ops.example.yaml
SALESOPS_DB=sales_ops.db

# Approval via Telegram (optional; config.approval.channel = telegram)
TELEGRAM_BOT_TOKEN=

# CRM Sync credentials (set per config.crm.provider)
HUBSPOT_TOKEN=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Leads

# Outbound email (optional real sender; default is a recording stub)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
